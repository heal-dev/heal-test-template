{
  "compilerOptions": {
    "target": "ES2019",
    "module": "NodeNext",
    "lib": ["ES2019", "DOM", "DOM.Iterable"],
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["tests/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
